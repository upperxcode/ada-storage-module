#!/bin/bash

# colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# print header
print_header() {
    echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${BOLD}  ada-storage-module CLI Menu       ${NC}${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
    echo ""
}

# print menu
print_menu() {
    echo -e "${PURPLE}📋 Opções disponíveis:${NC}"
    echo ""
    echo -e "${GREEN}  1️⃣  ${BOLD}run${NC}          - Executar aplicação"
    echo -e "${GREEN}  2️⃣  ${BOLD}build${NC}       - Compilar o projeto"
    echo -e "${GREEN}  3️⃣  ${BOLD}test${NC}        - Executar testes unitários"
    echo -e "${GREEN}  4️⃣  ${BOLD}test-all${NC}    - Executar todos os testes"
    echo -e "${GREEN}  5️⃣  ${BOLD}vet${NC}         - Executar go vet"
    echo -e "${GREEN}  6️⃣  ${BOLD}fmt${NC}         - Formatar código"
    echo -e "${GREEN}  7️⃣  ${BOLD}clean${NC}       - Limpar arquivos compilados"
    echo -e "${GREEN}  8️⃣  ${BOLD}dev${NC}         - Iniciar modo desenvolvimento"
    echo ""
    echo -e "${YELLOW}  ❌  Q - Sair${NC}"
    echo ""
}

# run command
run_cmd() {
    local cmd="$1"
    echo -e "${BLUE}🔧 Executando: $cmd${NC}"
    echo ""
    eval "$cmd"
    local exit_code=$?
    if [ $exit_code -eq 0 ]; then
        echo ""
        echo -e "${GREEN}✅ Comando concluído com sucesso!${NC}"
    else
        echo ""
        echo -e "${RED}❌ Erro ao executar o comando!${NC}"
    fi
    echo ""
    read -p "$(echo -e "${YELLOW}⏎ Pressione Enter para continuar...${NC}")"
}

# show header and menu
show_menu() {
    clear
    print_header
    print_menu
}

# main menu loop
while true; do
    show_menu
    
    read -p "$(echo -e "${CYAN}➤ Selecione uma opção: ${NC})" choice
    
    case $choice in
        1|run)
            run_cmd "go run ./storage/..."
            ;;
        2|build)
            run_cmd "go build -o bin/ada-storage ./storage/..."
            ;;
        3|test)
            run_cmd "go test -v ./storage/..."
            ;;
        4|test-all)
            run_cmd "go test -v -race ./storage/... && go vet ./storage/..."
            ;;
        5|vet)
            run_cmd "go vet ./storage/..."
            ;;
        6|fmt)
            run_cmd "go fmt ./storage/..."
            ;;
        7|clean)
            run_cmd "rm -rf bin/ && go clean"
            ;;
        8|dev)
            echo -e "${YELLOW}🚀 Iniciando modo desenvolvimento...${NC}"
            echo -e "${BLUE}Pressione Ctrl+C para sair${NC}"
            echo ""
            while true; do
                go build -o bin/ada-storage ./storage/... 2>&1
                if [ $? -eq 0 ]; then
                    echo -e "${GREEN}✓ Build OK - $(date '+%H:%M:%S')${NC}"
                else
                    echo -e "${RED}✗ Build FAIL - $(date '+%H:%M:%S')${NC}"
                fi
                sleep 2
            done
            ;;
        q|Q)
            echo -e "${GREEN}👋 Até logo!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}❌ Opção inválida!${NC}"
            read -p "$(echo -e "${YELLOW}⏎ Pressione Enter para tentar novamente...${NC}")"
            ;;
    esac
done