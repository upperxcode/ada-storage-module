#!/bin/bash

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m'

# Print header
print_header() {
    echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${BOLD}  ada-storage-module CLI Menu       ${NC}${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
    echo ""
}

# Print menu
print_menu() {
    echo -e "${PURPLE}Opções disponíveis:${NC}"
    echo ""
    echo -e "${GREEN}  1)  run          - Executar aplicacao${NC}"
    echo -e "${GREEN}  2)  build        - Compilar projeto${NC}"
    echo -e "${GREEN}  3)  test         - Testes unitarios${NC}"
    echo -e "${GREEN}  4)  test-all     - Todos os testes${NC}"
    echo -e "${GREEN}  5)  vet          - Executar go vet${NC}"
    echo -e "${GREEN}  6)  fmt          - Formatar codigo${NC}"
    echo -e "${GREEN}  7)  clean        - Limpar arquivos${NC}"
    echo -e "${GREEN}  8)  dev          - Modo desenvolvimento${NC}"
    echo ""
    echo -e "${YELLOW}  Q)  Sair${NC}"
    echo ""
}

# Run command
run_cmd() {
    local cmd="$1"
    echo -e "${BLUE}Executando: $cmd${NC}"
    echo ""
    eval "$cmd"
    local exit_code=$?
    if [ $exit_code -eq 0 ]; then
        echo ""
        echo -e "${GREEN}Sucesso!${NC}"
    else
        echo ""
        echo -e "${RED}Erro!${NC}"
    fi
    echo ""
    read -p "Pressione Enter para continuar..."
}

# Main menu
while true; do
    clear
    print_header
    print_menu
    read -p "Selecione uma opcao: " choice
    
    case $choice in
        1)
            run_cmd "go run ./storage/..."
            ;;
        2)
            run_cmd "go build -o bin/ada-storage ./storage/..."
            ;;
        3)
            run_cmd "go test -v ./storage/..."
            ;;
        4)
            run_cmd "go test -v -race ./storage/... && go vet ./storage/..."
            ;;
        5)
            run_cmd "go vet ./storage/..."
            ;;
        6)
            run_cmd "go fmt ./storage/..."
            ;;
        7)
            run_cmd "rm -rf bin/ && go clean"
            ;;
        8)
            echo -e "${YELLOW}Modo desenvolvimento - Ctrl+C para sair${NC}"
            echo ""
            while true; do
                go build -o bin/ada-storage ./storage/... 2>&1
                if [ $? -eq 0 ]; then
                    echo -e "${GREEN}Build OK - $(date '+%H:%M:%S')${NC}"
                else
                    echo -e "${RED}Build FAIL - $(date '+%H:%M:%S')${NC}"
                fi
                sleep 2
            done
            ;;
        q|Q)
            echo -e "${GREEN}Ate logo!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Opcao invalida!${NC}"
            read -p "Pressione Enter para tentar novamente..."
            ;;
    esac
done